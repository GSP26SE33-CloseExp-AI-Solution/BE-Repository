{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=CloseExpAIDb;Username=postgres;Password=password;"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyHere_MinimumLength32Characters!",
    "Issuer": "CloseExpAISolution",
    "Audience": "CloseExpAISolution",
    "ExpiryInMinutes": 60
  },
  "AIService": {
    "BaseUrl": "http://localhost:8000",
    "ApiKey": "your-secure-api-key-here",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelayMs": 1000,
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 60
    },
    "Caching": {
      "EnableCaching": true,
      "DefaultCacheDurationMinutes": 5,
      "PricingCacheDurationMinutes": 2
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "CloseExpAISolution.Application.AIService": "Debug"
    }
  },
  "AllowedHosts": "*"
}
