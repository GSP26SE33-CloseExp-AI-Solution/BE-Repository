                  "method": "POST",
                  "header": [
                     {
                        "key": "Content-Type",
                        "value": "application/json"
                     }
                  ],
                  "body": {
                     "mode": "raw",
                     "raw": "{\n  \"deliveryDate\": {{deliveryDateJson}},\n  \"timeSlotId\": {{timeSlotIdJson}},\n  \"collectionId\": {{collectionIdJson}},\n  \"maxDistanceKm\": {{maxDistanceKm}},\n  \"maxOrdersPerGroup\": {{maxOrdersPerGroup}}\n}"
