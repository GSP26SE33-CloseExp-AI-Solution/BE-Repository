                        "type": "text/javascript",
                        "exec": [
                           "const idsJson = pm.collectionVariables.get('orderItemIdsJson') || '[]';",
                           "if (idsJson.trim() === '[]') {",
                           "  console.warn('orderItemIdsJson is empty. Set it to a JSON array, e.g. [\"guid1\",\"guid2\"]');",
                           "}",
                           "if (!pm.collectionVariables.get('targetDraftGroupId')) {",
                           "  console.warn('targetDraftGroupId is empty. Generate at least 2 drafts or set it manually.');",
                           "}"
                        ]
