                           "const j = pm.response.json();",
                           "pm.test('Status 200', () => pm.response.code === 200);",
                           "pm.test('Envelope success=true', () => pm.expect(j.success).to.eql(true));",
                           "const groups = Array.isArray(j?.data) ? j.data : [];",
                           "pm.test('Generated at least 1 group', () => pm.expect(groups.length).to.be.greaterThan(0));",
                           "if (groups[0]?.deliveryGroupId) pm.collectionVariables.set('draftGroupId', groups[0].deliveryGroupId);",
                           "if (groups[1]?.deliveryGroupId) pm.collectionVariables.set('targetDraftGroupId', groups[1].deliveryGroupId);"
                        ]
