      {
         "name": "00 - Setup & Auth",
         "item": [
            {
               "name": "00.1 Admin Login",
               "event": [
                  {
                     "listen": "test",
                     "script": {
                        "type": "text/javascript",
                        "exec": [
                           "const j = pm.response.json();",
                           "pm.test('Status 200', () => pm.response.code === 200);",
                           "pm.test('Envelope success=true', () => pm.expect(j.success).to.eql(true));",
                           "if (j?.data?.accessToken) pm.collectionVariables.set('adminToken', j.data.accessToken);",
                           "if (j?.data?.refreshToken) pm.collectionVariables.set('adminRefreshToken', j.data.refreshToken);",
                           "if (j?.data?.user?.userId) pm.collectionVariables.set('adminUserId', j.data.user.userId);"
                        ]
                     }
                  }
               ],
               "request": {
                  "method": "POST",
                  "header": [
                     {
                        "key": "Content-Type",
                        "value": "application/json"
                     }
                  ],
                  "body": {
                     "mode": "raw",
                     "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
                  },
                  "url": {
                     "raw": "{{baseUrl}}/auth/login",
                     "host": [
                        "{{baseUrl}}"
                     ],
                     "path": [
                        "auth",
                        "login"
                     ]
                  }
               },
               "response": []
