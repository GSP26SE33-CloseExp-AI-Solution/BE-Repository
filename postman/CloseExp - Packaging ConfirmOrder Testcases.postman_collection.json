   },
   "item": [
      {
         "name": "00 - Setup & Auth",
         "item": [
            {
               "name": "00.1 PackagingStaff Login",
               "event": [
                  {
                     "listen": "test",
                     "script": {
                        "type": "text/javascript",
                        "exec": [
                           "const j = pm.response.json();",
                           "pm.test('Status 200', () => pm.response.code === 200);",
                           "pm.test('Envelope success=true', () => pm.expect(j.success).to.eql(true));",
                           "if (j?.data?.accessToken) pm.collectionVariables.set('packagingToken', j.data.accessToken);",
                           "if (j?.data?.user?.userId) pm.collectionVariables.set('packagingUserId', j.data.user.userId);"
                        ]
                     }
                  }
               ],
               "request": {
                  "method": "POST",
                  "header": [
                     {
                        "key": "Content-Type",
                        "value": "application/json"
                     }
                  ],
                  "body": {
                     "mode": "raw",
                     "raw": "{\n  \"email\": \"{{packagingEmail}}\",\n  \"password\": \"{{packagingPassword}}\"\n}"
                  },
                  "url": {
                     "raw": "{{baseUrl}}/auth/login",
                     "host": [
                        "{{baseUrl}}"
                     ],
                     "path": [
                        "auth",
                        "login"
                     ]
                  }
               },
               "response": []
            }
         ]
      },
      {
