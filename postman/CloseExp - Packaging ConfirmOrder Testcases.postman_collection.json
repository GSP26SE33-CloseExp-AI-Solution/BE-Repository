   "info": {
      "_postman_id": "f1c3d9e2-4d7a-4d5b-8f62-9b3f4c8c6b2a",
      "name": "CloseExp - Packaging ConfirmOrder Testcases",
      "description": "ConfirmOrderAsync testcases for PackagingStaff.\n\nHow to use:\n1) Set collection variables: baseUrl, packagingEmail, packagingPassword.\n2) Run folder 00 then folder 01 in order.",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
