{
  "info": {
    "_postman_id": "request-unlock-flow-2024-v2",
    "name": "CloseExp - Request Unlock Flow",
    "description": "Test flow cho API request-unlock va admin duyet.\n\n## Huong dan:\n1. Sua bien `baseUrl` cho dung moi truong\n2. Sua `adminEmail`, `adminPassword` cho dung\n3. Chay `0. [Setup] Admin Login` truoc\n4. Chay theo thu tu hoac dung Runner chay tu dong\n\n## Luu y:\n- Cac request co script tu dong luu token, userId\n- Kiem tra tab Tests de xem ket qua",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7001/api",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@closeexp.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "Admin@123",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testUserEmail",
      "value": "testuser@example.com",
      "type": "string"
    },
    {
      "key": "testUserPassword",
      "value": "User@123",
      "type": "string"
    },
    {
      "key": "testUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "bannedUserEmail",
      "value": "banned@example.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. [Setup] Admin Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Clear old token before login",
              "pm.collectionVariables.set('adminToken', '');",
              "pm.collectionVariables.set('adminUserId', '');",
              "",
              "console.log('Pre-request: Clearing old admin token...');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test response status",
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has success = true', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test('Response contains accessToken', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('accessToken');",
              "    pm.expect(jsonData.data.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "",
              "// Save token and userId for subsequent requests",
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.success && jsonData.data) {",
              "        pm.collectionVariables.set('adminToken', jsonData.data.accessToken);",
              "        ",
              "        // Decode JWT to get userId",
              "        var token = jsonData.data.accessToken;",
              "        var payload = token.split('.')[1];",
              "        var decoded = JSON.parse(atob(payload));",
              "        var userId = decoded['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'] || decoded.sub || decoded.nameid;",
              "        ",
              "        if (userId) {",
              "            pm.collectionVariables.set('adminUserId', userId);",
              "            console.log('Admin userId saved: ' + userId);",
              "        }",
              "        console.log('Admin token saved successfully!');",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Dang nhap Admin de lay token.\n\n**Auto-save:** adminToken, adminUserId"
      },
      "response": []
    },
    {
      "name": "1. [Setup] Get All Users - Find Test User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Ensure we have admin token",
              "var token = pm.collectionVariables.get('adminToken');",
              "if (!token) {",
              "    console.warn('WARNING: adminToken is empty. Run \"0. Admin Login\" first!');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Admin accounts are NOT in the list', function() {",
              "    var jsonData = pm.response.json();",
              "    var users = jsonData.data || [];",
              "    var adminUsers = users.filter(u => u.roleName === 'Admin' || u.roleId === 1);",
              "    pm.expect(adminUsers.length).to.equal(0, 'Admin accounts should be filtered out');",
              "});",
              "",
              "// Find a non-admin user to use for testing",
              "var jsonData = pm.response.json();",
              "var users = jsonData.data || [];",
              "var testUserEmail = pm.collectionVariables.get('testUserEmail');",
              "",
              "// Try to find user by email first",
              "var testUser = users.find(u => u.email === testUserEmail);",
              "",
              "// If not found, pick first Active user",
              "if (!testUser) {",
              "    testUser = users.find(u => u.status === 'Active' && u.roleName !== 'Admin');",
              "}",
              "",
              "if (testUser) {",
              "    pm.collectionVariables.set('testUserId', testUser.userId);",
              "    pm.collectionVariables.set('testUserEmail', testUser.email);",
              "    console.log('Test user found: ' + testUser.email + ' (ID: ' + testUser.userId + ')');",
              "} else {",
              "    console.warn('No suitable test user found. Create one manually.');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Lay danh sach users, tim user de test.\n\n**Auto-save:** testUserId, testUserEmail\n**Validate:** Admin khong co trong list"
      },
      "response": []
    },
    {
      "name": "2. [Prep] Admin Lock Test User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var testUserId = pm.collectionVariables.get('testUserId');",
              "if (!testUserId) {",
              "    console.error('ERROR: testUserId is empty. Run step 1 first!');",
              "}",
              "console.log('Locking user: ' + testUserId);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('User status is now Locked', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data.status).to.equal('Locked');",
              "});",
              "",
              "pm.test('Response message confirms lock', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('thành công');",
              "});",
              "",
              "console.log('User locked. Refresh tokens should be revoked. Email notification sent.');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Locked\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/{{testUserId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{testUserId}}",
            "status"
          ]
        },
        "description": "Admin khoa user de test.\n\n**Side effects:**\n- Revoke tat ca refresh token\n- Gui email thong bao"
      },
      "response": []
    },
    {
      "name": "3. [Test] Locked User Cannot Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "console.log('Testing login with locked account: ' + pm.collectionVariables.get('testUserEmail'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 (Bad Request)', function() {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Response has success = false', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.false;",
              "});",
              "",
              "pm.test('Error message indicates account is locked', function() {",
              "    var jsonData = pm.response.json();",
              "    var msg = (jsonData.message || '').toLowerCase();",
              "    pm.expect(msg).to.satisfy(function(m) {",
              "        return m.includes('khóa') || m.includes('locked') || m.includes('bị khóa');",
              "    }, 'Message should mention locked status');",
              "});",
              "",
              "console.log('Expected behavior: Locked user cannot login. FE should show unlock request button.');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "User bi Locked co gang dang nhap.\n\n**Expected:** 400 + message \"bi khoa\""
      },
      "response": []
    },
