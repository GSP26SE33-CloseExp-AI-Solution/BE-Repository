    {
      "name": "11. [Bonus] Admin Direct Unban (Banned -> Active)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// You need to manually set a banned user ID here or via collection variable",
              "var bannedUserId = pm.collectionVariables.get('bannedUserId');",
              "if (!bannedUserId) {",
              "    console.warn('bannedUserId not set. Set it manually in collection variables.');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// This test is optional - only runs if you have a banned user",
              "if (pm.response.code === 200) {",
              "    pm.test('User unbanned successfully', function() {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData.success).to.be.true;",
              "        pm.expect(jsonData.data.status).to.equal('Active');",
              "    });",
              "    console.log('SUCCESS: Banned user is now Active!');",
              "} else if (pm.response.code === 404) {",
              "    console.log('User not found - set bannedUserId variable');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Active\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/{{bannedUserId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{bannedUserId}}",
            "status"
          ]
        },
        "description": "Admin truc tiep mo ban: Banned -> Active\n\n**Luu y:** Set `bannedUserId` trong collection variables"
      },
      "response": []
    }
  ]
