                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timeSlotId\": \"{{timeSlotId}}\",\n  \"maxDistanceKm\": 5,\n  \"maxOrdersPerGroup\": 20\n}"
            },
