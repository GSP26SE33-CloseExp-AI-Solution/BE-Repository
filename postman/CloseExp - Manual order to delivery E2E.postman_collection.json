                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && Array.isArray(j.data) && j.data.length && j.data[0].deliveryGroupId) {",
                  "  pm.collectionVariables.set('deliveryGroupId', j.data[0].deliveryGroupId);",
                  "}"
