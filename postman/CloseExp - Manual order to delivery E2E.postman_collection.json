    {
      "name": "2 — Tạo đơn",
      "description": "Luồng chính: chỉ **POST Orders/my-orders (customer)** (DELIVERY) là bắt buộc cho E2E. Request **2b PICKUP** và **POST Orders (manual userId)** là tùy chọn — không ghi đè `orderId`/`orderCode`.",
      "item": [
        {
          "name": "POST Orders/my-orders (customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data) {",
                  "  if (j.data.orderId) pm.collectionVariables.set('orderId', j.data.orderId);",
                  "  if (j.data.orderCode) pm.collectionVariables.set('orderCode', j.data.orderCode);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timeSlotId\": \"{{timeSlotId}}\",\n  \"collectionId\": null,\n  \"deliveryType\": \"DELIVERY\",\n  \"addressId\": null,\n  \"deliveryFee\": 0,\n  \"deliveryNote\": \"Postman manual test\",\n  \"orderItems\": [\n    {\n      \"lotId\": \"{{lotId}}\",\n      \"quantity\": 1,\n      \"unitPrice\": 10000\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/Orders/my-orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "Orders",
