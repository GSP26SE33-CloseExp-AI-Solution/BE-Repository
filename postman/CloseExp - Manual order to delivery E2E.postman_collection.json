      "name": "6 — Shipper giao hàng",
      "item": [
        {
          "name": "GET delivery/groups/my",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{deliveryToken}}",
