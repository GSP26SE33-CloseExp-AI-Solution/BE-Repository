              ]
            }
          },
          "response": []
        },
        {
          "name": "GET delivery/groups/drafts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "const items = j.data && j.data.items;",
                  "let cur = pm.collectionVariables.get('deliveryGroupId');",
                  "if (cur && String(cur).length > 10 && !String(cur).includes('{{')) { return; }",
                  "if (j.success && items && items.length) {",
                  "  const draft = items.find((g) => g.status === 'Draft') || items[0];",
                  "  if (draft && draft.deliveryGroupId) {",
                  "    pm.collectionVariables.set('deliveryGroupId', draft.deliveryGroupId);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
