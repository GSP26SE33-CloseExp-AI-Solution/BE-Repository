              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timeSlotId\": \"{{timeSlotId}}\",\n  \"collectionId\": \"{{collectionId}}\",\n  \"deliveryType\": \"PICKUP\",\n  \"addressId\": null,\n  \"deliveryFee\": 0,\n  \"deliveryNote\": \"Postman PICKUP test — không ghi đè orderId luồng chính\",\n  \"orderItems\": [\n    {\n      \"lotId\": \"{{lotId}}\",\n      \"quantity\": 1,\n      \"unitPrice\": 10000\n    }\n  ]\n}"
            },
