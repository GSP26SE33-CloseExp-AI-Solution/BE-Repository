          "name": "3.2 POST nearby — radiusKm 500 (tối đa hợp lệ; clamp theo PickupSearch:MaxRadiusKm)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('OK', () => pm.expect(j.success).to.be.true);",
                  "const pts = j.data || [];",
                  "const maxKm = parseFloat(pm.collectionVariables.get('pickupMaxRadiusKm') || '50');",
                  "pm.test('Mọi distanceKm <= MaxRadiusKm sau clamp (config)', () => {",
                  "  pts.forEach((p) => {",
                  "    pm.expect(p.distanceKm).to.be.a('number');",
                  "    pm.expect(p.distanceKm).to.be.at.most(maxKm + 0.002);",
                  "  });",
                  "});",
                  "const dists = pts.map((p) => p.distanceKm).filter((d) => d != null);",
                  "pm.test('Sắp xếp không giảm theo distanceKm (BE: OrderBy distance)', () => {",
                  "  for (let i = 1; i < dists.length; i++) {",
                  "    pm.expect(dists[i]).to.be.at.least(dists[i - 1] - 1e-6);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
