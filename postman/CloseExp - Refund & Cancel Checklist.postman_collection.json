      ]
    },
    {
      "name": "4 - Email Job Checklist (manual)",
      "description": "Xac minh qua mailbox/log worker:\n- Created -> mail tiep nhan\n- Approved -> mail da phe duyet\n- Rejected -> mail bi tu choi\n- Completed -> mail hoan tat\n- Event ngoai whitelist -> skip + warning log",
      "item": [
        {
          "name": "GET Refunds/{refundId} (check latest status before mail verify)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Refunds/{{refundId}}"
          }
        }
      ]
    },
    {
      "name": "5 - FE React Checklist (manual)",
      "description": "MyOrderDetailPage:\n- Order Paid + chua qua cancelDeadline -> thay nut Huy don\n- Bam huy thanh cong -> reload order + hien progress refund\nMyOrdersPage:\n- Order co refund -> badge phu Refund: <status>\nCase qua han:\n- Khong cho huy hoac BE tra loi phu hop, FE hien message ro rang",
      "item": [
        {
          "name": "GET Orders/{orderId} (manual FE cross-check)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{userToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Orders/{{orderId}}"
          }
        }
      ]
    }
  ]
