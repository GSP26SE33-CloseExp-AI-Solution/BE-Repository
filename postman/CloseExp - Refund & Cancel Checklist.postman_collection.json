          "name": "GET Refunds (marketing token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Marketing can access all refunds', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{marketingToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Refunds"
          }
        },
        {
          "name": "GET Refunds (normal user forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Normal user forbidden on Refunds list', function () {",
                  "  pm.expect(pm.response.code).to.equal(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{userToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Refunds"
          }
        },
        {
          "name": "GET Refunds/{refundId} (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin can view any refund detail', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Refunds/{{refundId}}"
          }
        },
        {
          "name": "GET Refunds/{refundId} (owner user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Owner can view own refund detail', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{userToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Refunds/{{refundId}}"
          }
        },
        {
          "name": "GET Refunds/{refundId} (other user forbidden/not found)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Other user cannot view foreign refund detail', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([403, 404]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{otherUserToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/Refunds/{{refundId}}"
          }
        }
      ]
    },
    {
      "name": "3 - Refund Status Transition",
      "description": "Luong dung: Pending -> Approved -> Completed hoac Pending -> Rejected",
      "item": [
        {
          "name": "PUT Refunds/{id}/approved (admin or marketing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Approve refund success for admin/marketing', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/Refunds/{{refundId}}/approved"
          }
        },
        {
          "name": "PUT Refunds/{id}/completed (admin or marketing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Complete refund success after approved', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
