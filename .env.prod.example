CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DB;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Ssl Mode=Require;Trust Server Certificate=true

JWT__KEY=REPLACE_WITH_STRONG_BASE64_OR_RANDOM_SECRET
JWT__ISSUER=CloseExpAI_Issuer
JWT__AUDIENCE=CloseExpAI_Audience
JWT__EXPIRYINMINUTES=60

GOOGLEAUTH__CLIENTID=your-google-client-id.apps.googleusercontent.com
GOOGLEAUTH__CLIENTSECRET=your-google-client-secret

MAPBOX__ACCESSTOKEN=your-mapbox-access-token

PAYOSSETTINGS__CLIENTID=your-payos-client-id
PAYOSSETTINGS__APIKEY=your-payos-api-key
PAYOSSETTINGS__CHECKSUMKEY=your-payos-checksum-key

EMAILSETTINGS__SMTPSERVER=smtp.your-provider.com
EMAILSETTINGS__SMTPPORT=587
EMAILSETTINGS__SMTPUSERNAME=your-email@example.com
EMAILSETTINGS__SMTPPASSWORD=your-smtp-password
EMAILSETTINGS__FROMEMAIL=noreply@your-domain.com
EMAILSETTINGS__FROMNAME=CloseExp AI

R2STORAGE__ACCOUNTID=your-account-id
R2STORAGE__ACCESSKEYID=your-access-key-id
R2STORAGE__SECRETACCESSKEY=your-secret-access-key
R2STORAGE__BUCKETNAME=your-bucket-name
R2STORAGE__ACCOUNTURL=https://your-account-id.r2.cloudflarestorage.com
