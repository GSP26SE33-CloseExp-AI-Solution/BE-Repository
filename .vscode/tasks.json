{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Compose Up",
      "type": "shell",
      "command": "docker compose up --build",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": "build"
    },
    {
      "label": "Docker: Compose Up (detached)",
      "type": "shell",
      "command": "docker compose up -d --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "type": "process",
      "label": "build",
      "command": "dotnet build",
      "args": [
        "${workspaceFolder}/src/CloseExpAISolution.API/CloseExpAISolution.API.csproj"
      ],
      "group": "build",
      "problemMatcher": ["$msCompile"]
    }
  ]
}
